# Copy to .env.local and fill in real values. .env.local is gitignored.
# Only EXPO_PUBLIC_* vars are exposed to the client bundle — never put secrets
# (service role keys, Apple/Cloudflare/Upstash keys, etc.) here. Those belong in
# Supabase secrets or EAS environment variables, never in the app bundle.

# Supabase (publishable / anon — safe for client)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Sign-In iOS client ID (public OAuth client ID).
# Format: <id>.apps.googleusercontent.com — used to derive the iOS URL scheme.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Superwall publishable API key (pk_...)
EXPO_PUBLIC_SUPERWALL_API_KEY=

# PostHog project (public client key phc_... + host)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
